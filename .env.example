# =============================================================
# Notifier configuration — copy this file to .env and fill in.
# .env is gitignored. NEVER commit real secrets.
# =============================================================

# Provider: "graph" (Microsoft Graph) or "smtp" (any SMTP relay)
NOTIFY_PROVIDER=graph

# --- Graph (Microsoft 365) --------------------------------------
# Tata Realty tenant + the AAD app already used by the mobile app.
# These are non-secret identifiers (safe to commit).
GRAPH_TENANT_ID=20692ac2-912f-4425-ab78-a937c909f459
GRAPH_CLIENT_ID=f62e1f79-aa9e-4eef-a6be-e6b5d6399fe6

# Auth flow:
#   "ropc"          = sign in as a user with username + password (delegated Mail.Send)
#   "client_secret" = app-only client credentials (application Mail.Send) — production
GRAPH_AUTH_FLOW=ropc

# ROPC flow (when GRAPH_AUTH_FLOW=ropc)
# Wrap the password in double quotes if it contains $ ! & etc.
GRAPH_USERNAME=apptest@tatarealty.in
GRAPH_PASSWORD=""

# client_credentials flow (when GRAPH_AUTH_FLOW=client_secret)
# GRAPH_FROM_ADDRESS=expense-noreply@tatarealty.in
# GRAPH_CLIENT_SECRET=

# --- SMTP --------------------------------------------------------
# Required only when NOTIFY_PROVIDER=smtp.
# Port 465 → SMTP_SECURE=true (implicit TLS)
# Port 587 → SMTP_SECURE=false (STARTTLS)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=""
SMTP_FROM=
# Set to "false" only for internal servers with self-signed certs.
SMTP_TLS_REJECT_UNAUTHORIZED=true

# --- Smoke test recipient ---------------------------------------
# Default = whoever is in GRAPH_USERNAME or SMTP_FROM (sender mails themselves).
NOTIFY_TEST_TO=

# --- Feature flag for production wiring later -------------------
NOTIFY_ENABLED=false
